<Window x:Class="GymFitnessSystem.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gym System - Login" 
        Height="720" Width="450" 
        UseLayoutRounding="True"
        WindowStartupLocation="CenterScreen" Background="Transparent"
        WindowStyle="None" AllowsTransparency="True">

    <Window.Resources>
        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="buttonBorder" Background="{TemplateBinding Background}" CornerRadius="10" Opacity="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="buttonBorder" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="buttonBorder" Property="Opacity" Value="0.70"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="20" Background="White" Margin="25">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" Color="#D1D5DB" ShadowDepth="2" Opacity="0.5"/>
        </Border.Effect>

        <!-- Am redus marginea de sus și jos de la 30 la 15 pentru a câștiga spațiu -->
        <Grid Margin="30,15,30,15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Zona de Logo fixă sus -->
            <StackPanel Grid.Row="0" Margin="0,10,0,10">
                <TextBlock Text="GYM PRO" FontSize="28" FontWeight="ExtraBold" 
                           Foreground="#1E40AF" HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Zona de conținut dinamic cu ScrollViewer (just in case) -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <Grid>
                    <!-- PANOU LOGIN -->
                    <StackPanel x:Name="PanelLogin" Visibility="Visible" VerticalAlignment="Top">
                        <TextBlock Text="Introduceți datele pentru acces" Foreground="#6B7280" 
                                   HorizontalAlignment="Center" Margin="0,0,0,25"/>

                        <TextBlock Text="Username" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="#374151"/>
                        <Border Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Padding="5">
                            <TextBox x:Name="txtUsername" BorderThickness="0" Background="Transparent" Height="30" VerticalContentAlignment="Center"/>
                        </Border>

                        <TextBlock Text="Parolă" FontWeight="SemiBold" Margin="0,15,0,5" Foreground="#374151"/>
                        <Border Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Padding="5">
                            <PasswordBox x:Name="txtPassword" BorderThickness="0" Background="Transparent" Height="30" VerticalContentAlignment="Center"/>
                        </Border>

                        <Button x:Name="btnLogin" Content="Conectare" Margin="0,25,0,0" Height="45" 
                                Click="btnLogin_Click" Style="{StaticResource ModernButtonStyle}" IsDefault="True"/>

                        <Button Content="Nu ai cont? Înregistrează-te" Margin="0,15,0,0" Background="Transparent" 
                                BorderThickness="0" Foreground="#2563EB" FontWeight="SemiBold" Click="SwitchToRegister_Click"/>
                    </StackPanel>

                    <!-- PANOU REGISTER -->
                    <StackPanel x:Name="PanelRegister" Visibility="Collapsed" VerticalAlignment="Top">
                        <TextBlock Text="Creează un cont nou" Foreground="#6B7280" 
                                   HorizontalAlignment="Center" Margin="0,0,0,15"/>

                        <TextBlock Text="Nume Complet" FontWeight="SemiBold" Margin="0,5,0,2" Foreground="#374151"/>
                        <Border Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Padding="5" Margin="0,0,0,8">
                            <TextBox x:Name="txtNewNume" BorderThickness="0" Background="Transparent" Height="28" VerticalContentAlignment="Center"/>
                        </Border>

                        <TextBlock Text="Username" FontWeight="SemiBold" Margin="0,5,0,2" Foreground="#374151"/>
                        <Border Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Padding="5" Margin="0,0,0,8">
                            <TextBox x:Name="txtNewUser" BorderThickness="0" Background="Transparent" Height="28" VerticalContentAlignment="Center"/>
                        </Border>

                        <TextBlock Text="Email" FontWeight="SemiBold" Margin="0,5,0,2" Foreground="#374151"/>
                        <Border Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Padding="5" Margin="0,0,0,8">
                            <TextBox x:Name="txtNewEmail" BorderThickness="0" Background="Transparent" Height="28" VerticalContentAlignment="Center"/>
                        </Border>

                        <TextBlock Text="Telefon" FontWeight="SemiBold" Margin="0,5,0,2" Foreground="#374151"/>
                        <Border Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Padding="5" Margin="0,0,0,8">
                            <TextBox x:Name="txtNewTel" BorderThickness="0" Background="Transparent" Height="28" VerticalContentAlignment="Center"/>
                        </Border>

                        <TextBlock Text="Parolă" FontWeight="SemiBold" Margin="0,5,0,2" Foreground="#374151"/>
                        <Border Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Padding="5" Margin="0,0,0,12">
                            <PasswordBox x:Name="txtNewPass" BorderThickness="0" Background="Transparent" Height="28" VerticalContentAlignment="Center"/>
                        </Border>

                        <Button x:Name="btnRegister" Content="Creează Cont" Margin="0,10,0,0" Height="45" 
                                Click="btnRegister_Click" Style="{StaticResource ModernButtonStyle}" Background="#059669" IsDefault="True"/>

                        <Button Content="Ai deja cont? Conectează-te" Margin="0,12,0,0" Background="Transparent" 
                                BorderThickness="0" Foreground="#2563EB" FontWeight="SemiBold" Click="SwitchToLogin_Click"/>
                    </StackPanel>
                </Grid>
            </ScrollViewer>

            <!-- Butonul de Exit rămâne întotdeauna la bază, în afara ScrollViewer-ului -->
            <Button Grid.Row="1" Content="Închide aplicația" VerticalAlignment="Bottom" Margin="0,0,0,5" Background="Transparent" 
                    BorderThickness="0" Foreground="#9CA3AF" Click="btnExit_Click" IsCancel="True"/>
        </Grid>
    </Border>
</Window>