<Window x:Class="GymFitnessSystem.Views.Admin.AdaugaProdusWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Produs Nou (Bar)" Height="410" Width="380"
        WindowStartupLocation="CenterOwner" Background="#F9FAFB">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Adaugă Produs în Stoc" FontSize="22" FontWeight="Bold" Foreground="#111827" Margin="0,0,0,15"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,5,0">

                <TextBlock Text="Categorie Produs:" Margin="0,5,0,2" FontWeight="SemiBold" Foreground="#374151"/>
                <ComboBox x:Name="cmbCategorieProdus" Padding="6" Margin="0,0,0,12" SelectedIndex="0">
                    <ComboBoxItem Content="Toate Categoriile"/>
                    <ComboBoxItem Content="🎒 Echipament și Accesorii"/>
                    <ComboBoxItem Content="☕ Băuturi și Rehidratare"/>
                    <ComboBoxItem Content="🍫 Gustări și Alimente Proteice"/>
                    <ComboBoxItem Content="💊 Suplimente Mari și Vitamine"/>
                </ComboBox>

                <TextBlock Text="Nume Produs:" Margin="0,5,0,2" FontWeight="SemiBold"/>
                <TextBox x:Name="txtNume" Padding="6" Margin="0,0,0,12"/>

                <TextBlock Text="Producător / Brand:" Margin="0,5,0,2" FontWeight="SemiBold"/>
                <TextBox x:Name="txtProducator" Padding="6" Margin="0,0,0,12"/>

                <TextBlock Text="Preț Vânzare (RON):" Margin="0,5,0,2" FontWeight="SemiBold"/>
                <TextBox x:Name="txtPret" Padding="6" Margin="0,0,0,12"/>

                <TextBlock Text="Stoc Inițial (Bucăți):" Margin="0,5,0,2" FontWeight="SemiBold"/>
                <TextBox x:Name="txtStoc" Padding="6" Margin="0,0,0,12" Text="0"/>

            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Anulează" Click="Anuleaza_Click" Width="90" Padding="8" Background="#9CA3AF" Foreground="White" BorderThickness="0" Margin="0,0,10,0"/>
            <Button Content="Salvează" Click="Salveaza_Click" Width="90" Padding="8" Background="#10B981" Foreground="White" BorderThickness="0" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>