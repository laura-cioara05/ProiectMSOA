<Window x:Class="GymFitnessSystem.Views.Admin.AdaugaServiciuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Abonament / Serviciu Nou" Height="480" Width="380"
        WindowStartupLocation="CenterOwner" Background="#F9FAFB">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Adaugă Ofertă / Serviciu" FontSize="22" FontWeight="Bold" Foreground="#111827" Margin="0,0,0,15"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,5,0">

                <TextBlock Text="Tip Serviciu / Categorie:" Margin="0,5,0,2" FontWeight="SemiBold" Foreground="#374151"/>
                <ComboBox x:Name="cmbCategorieServiciu" Padding="6" Margin="0,0,0,12" SelectedIndex="0" SelectionChanged="CmbCategorieServiciu_SelectionChanged">
                    <ComboBoxItem Content="💪 Abonament"/>
                    <ComboBoxItem Content="👥 Clasa de Grup"/>
                    <ComboBoxItem Content="👟 Antrenor Personal"/>
                </ComboBox>

                <TextBlock Text="Denumire Pachet / Serviciu:" Margin="0,5,0,2" FontWeight="SemiBold" Foreground="#374151"/>
                <TextBox x:Name="txtNume" Padding="6" Margin="0,0,0,12"/>

                <TextBlock Text="Preț (RON):" Margin="0,5,0,2" FontWeight="SemiBold" Foreground="#374151"/>
                <TextBox x:Name="txtPret" Padding="6" Margin="0,0,0,12"/>

                <TextBlock Text="Durată (Zile / Valabilitate):" Margin="0,5,0,2" FontWeight="SemiBold" Foreground="#374151"/>
                <TextBox x:Name="txtDurata" Padding="6" Margin="0,0,0,12" Text="30"/>

                <CheckBox x:Name="chkProgramare" Content="Necesită programare în aplicație" Margin="0,5,0,12" FontWeight="SemiBold"/>

                <TextBlock Text="Descriere:" Margin="0,5,0,2" FontWeight="SemiBold" Foreground="#374151"/>
                <TextBox x:Name="txtDescriere" Padding="6" Margin="0,0,0,12" Height="60" TextWrapping="Wrap" AcceptsReturn="True"/>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Anulează" Click="Anuleaza_Click" Width="90" Padding="8" Background="#9CA3AF" Foreground="White" BorderThickness="0" Margin="0,0,10,0"/>
            <Button Content="Salvează" Click="Salveaza_Click" Width="90" Padding="8" Background="#1E40AF" Foreground="White" BorderThickness="0" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>