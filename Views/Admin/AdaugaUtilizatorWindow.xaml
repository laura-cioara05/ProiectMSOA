<Window x:Class="GymFitnessSystem.Views.Admin.AdaugaUtilizatorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Adaugă Utilizator Nou" Height="500" Width="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Background="#F3F4F6">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Membru / Angajat Nou" FontSize="20" FontWeight="Bold" Foreground="#111827" Margin="0,0,0,20"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="10">
                <TextBlock Text="Username:" Margin="0,5,0,2" FontWeight="SemiBold"/>
                <TextBox x:Name="txtUsername" 
             Text="{Binding Username, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" 
             Padding="5"/>

                <TextBlock Text="Nume Complet:" Margin="0,10,0,2" FontWeight="SemiBold"/>
                <TextBox x:Name="txtNume" 
             Text="{Binding NumeComplet, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
             Padding="5"/>

                <TextBlock Text="Email:" Margin="0,10,0,2" FontWeight="SemiBold"/>
                <TextBox x:Name="txtEmail" 
             Text="{Binding Email, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" 
             Padding="5"/>

                <TextBlock Text="Telefon:" Margin="0,10,0,2" FontWeight="SemiBold"/>
                <TextBox x:Name="txtTelefon" 
             Text="{Binding Telefon, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" 
             Padding="5"/>

                <TextBlock Text="Parolă Inițială:" Margin="0,10,0,2" FontWeight="SemiBold"/>
                <TextBox x:Name="txtParola" 
             Text="{Binding Parola, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" 
             Padding="5"/>

                <TextBlock Text="Rol:" Margin="0,10,0,2" FontWeight="SemiBold"/>
                <ComboBox x:Name="cmbRol" Padding="5" Margin="0,0,0,20"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Salvează" Click="Salveaza_Click" Width="100" Margin="0,0,10,0" Background="#10B981" Foreground="White" BorderThickness="0" Padding="5"/>
                    <Button Content="Anulează" Click="Anuleaza_Click" Width="100" Background="#EF4444" Foreground="White" BorderThickness="0" Padding="5"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        
    </Grid>
</Window>
