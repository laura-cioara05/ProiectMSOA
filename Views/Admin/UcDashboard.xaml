<UserControl x:Class="GymFitnessSystem.Views.Admin.UcDashboard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="10">
            <Grid Margin="10,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock x:Name="lblSalutAdmin" Text="Bun venit în panoul de control," FontSize="14" Foreground="#6B7280"/>
                    <TextBlock x:Name="lblTitluDashboard" Text="FitZone1 Gym " FontSize="28" FontWeight="Bold" Foreground="#111827"/>
                </StackPanel>
            </Grid>

            <UniformGrid Columns="2" Height="400" Margin="0,0,0,20">
                <Border Background="White" Margin="10" CornerRadius="15" Padding="20">
                    <StackPanel>
                        <TextBlock Text="Distribuție Membri per Tip Abonament" FontWeight="Bold" FontSize="16" Foreground="#1F2937" Margin="0,0,0,10"/>
                        <lvc:CartesianChart Height="300" x:Name="ChartAbonamente"/>
                    </StackPanel>
                </Border>

                <Border Background="White" Margin="10" CornerRadius="15" Padding="20">
                    <StackPanel>
                        <TextBlock Text="Distribuție Metode de Plată (Procentual)" FontWeight="Bold" FontSize="16" Foreground="#1F2937" Margin="0,0,0,10"/>
                        <lvc:PieChart Height="300" x:Name="chartMetodePlata" LegendPosition="Right"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Grid Margin="10,0,10,10" Height="250">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.8*"/>
                    <ColumnDefinition Width="1.2*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="White" CornerRadius="15" Padding="20" Margin="0,0,10,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Activitate Recentă (Live SQL Feed)" FontSize="18" FontWeight="Bold" Foreground="#111827" Margin="0,0,0,15"/>

                        <ListBox Grid.Row="1" x:Name="lstActivitateRecenta" BorderThickness="0" Background="Transparent">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" FontSize="14" Foreground="#374151" Margin="0,6,0,6"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>

                <Border Grid.Column="1" Background="#E5E7EB" CornerRadius="15" Padding="20">
                    <StackPanel>
                        <TextBlock Text="Informații despre noi" FontSize="18" FontWeight="Bold" Foreground="#1F2937" Margin="0,0,0,15"/>
                        <TextBlock Text="📍 Adresă Curentă:" FontSize="12" Foreground="#6B7280" FontWeight="SemiBold"/>
                        <TextBlock x:Name="lblDashAdresa" Text="Se încarcă..." FontSize="14" FontWeight="Medium" Foreground="#111827" Margin="0,2,0,15" TextWrapping="Wrap"/>
                        <TextBlock Text="🕒 Program Funcționare:" FontSize="12" Foreground="#6B7280" FontWeight="SemiBold"/>
                        <TextBlock x:Name="lblDashProgram" Text="Se încarcă..." FontSize="14" FontWeight="Medium" Foreground="#111827" Margin="0,2,0,15"/>
                        <TextBlock Text="📞 Contact Suport:" FontSize="12" Foreground="#6B7280" FontWeight="SemiBold"/>
                        <TextBlock x:Name="lblDashTelefon" Text="Se încarcă..." FontSize="14" FontWeight="Medium" Foreground="#111827"/>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>