<UserControl x:Class="GymFitnessSystem.Views.Admin.UcManagement"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             Background="Transparent">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Management Economic &amp; Gestiune" FontSize="28" FontWeight="Bold" Foreground="#111827" Margin="10,0,0,20"/>

        <TabControl Grid.Row="1" Background="White" BorderBrush="#E5E7EB" BorderThickness="1" Margin="10">

            <TabItem Header="💰 Prețuri Oferte &amp; Servicii" Padding="15,8" FontSize="14" FontWeight="SemiBold">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                        <Button Content="+ Serviciu/Abonament Nou" Click="AdaugaServiciu_Click" Background="#1E40AF" Foreground="White" Padding="12,6" BorderThickness="0" FontWeight="Bold" Margin="0,0,20,0"/>

                        <TextBlock Text="Filtrează după Categorie:" VerticalAlignment="Center" Margin="0,0,5,0" FontWeight="SemiBold"/>
                        <ComboBox x:Name="cmbFiltruServicii" Width="180" Padding="5" SelectionChanged="CmbFiltruServicii_SelectionChanged">
                            <ComboBoxItem Content="Toate Categoriile"/>
                            <ComboBoxItem Content="Abonament"/>
                            <ComboBoxItem Content="Clasa de Grup"/>
                            <ComboBoxItem Content="Antrenor Personal"/>
                        </ComboBox>
                    </StackPanel>

                    <DataGrid x:Name="dgServicii" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False" RowHeight="40" FontSize="14" RowEditEnding="dgServicii_RowEditEnding">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Denumire" Binding="{Binding Nume, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="2*"/>
                            <DataGridTextColumn Header="Preț (RON)" Binding="{Binding Pret, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=\{0:F2\}}" Width="1*"/>
                            <DataGridTextColumn Header="Durată (Zile)" Binding="{Binding DurataZile, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="1.2*"/>
                            <DataGridCheckBoxColumn Header="Necesită Programare" Binding="{Binding NecesitaProgramare, UpdateSourceTrigger=PropertyChanged}" Width="1.5*"/>
                            <DataGridTextColumn Header="Descriere" Binding="{Binding Descriere, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="3*"/>
                           
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="📦 Monitorizare Stocuri Bar" Padding="15,8" FontSize="14" FontWeight="SemiBold">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                        <Button Content="+ Produs Nou (Bar)" Click="AdaugaProdus_Click" Background="#10B981" Foreground="White" Padding="12,6" BorderThickness="0" FontWeight="Bold" Margin="0,0,10,0"/>
                        <Button Content="⚡ Adaugă Stoc (+20 selectat)" Click="AprovizioneazaRapid_Click" Background="#F59E0B" Foreground="White" Padding="12,6" BorderThickness="0" FontWeight="Bold" Margin="0,0,20,0"/>

                        <TextBlock Text="Filtrează după Categorie:" VerticalAlignment="Center" Margin="0,0,5,0" FontWeight="SemiBold"/>
                        <ComboBox x:Name="cmbFiltruProduse" Width="220" Padding="5" SelectionChanged="CmbFiltruProduse_SelectionChanged">
                            <ComboBoxItem Content="Toate Categoriile"/>
                            <ComboBoxItem Content="🎒 Echipament și Accesorii"/>
                            <ComboBoxItem Content="☕ Băuturi și Rehidratare"/>
                            <ComboBoxItem Content="🍫 Gustări și Alimente Proteice"/>
                            <ComboBoxItem Content="💊 Suplimente Mari și Vitamine"/>
                        </ComboBox>
                    </StackPanel>

                    <DataGrid x:Name="dgProduse" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False" RowHeight="40" FontSize="14" RowEditEnding="dgProduse_RowEditEnding">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Produs" Binding="{Binding Nume, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="2*"/>
                            <DataGridTextColumn Header="Producător" Binding="{Binding Producator, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="1.5*"/>
                            <DataGridTextColumn Header="Preț" Binding="{Binding Pret, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=\{0:F2\}}" Width="1*"/>

                            <DataGridTextColumn Header="Stoc Disponibil" Binding="{Binding Stoc, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="1.2*">
                                <DataGridTextColumn.CellStyle>
                                    <Style TargetType="DataGridCell">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Stoc}" Value="0">
                                                <Setter Property="Background" Value="#FEE2E2"/>
                                                <Setter Property="Foreground" Value="Red"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGridTextColumn.CellStyle>
                                
                            </DataGridTextColumn>

                            <DataGridTemplateColumn Header="Categorie" Width="2*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Descriere}" VerticalAlignment="Center" Margin="5,0,0,0"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <ComboBox SelectedValue="{Binding Descriere, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" SelectedValuePath="Content">
                                            <ComboBoxItem Content="🎒 Echipament și Accesorii"/>
                                            <ComboBoxItem Content="☕ Băuturi și Rehidratare"/>
                                            <ComboBoxItem Content="🍫 Gustări și Alimente Proteice"/>
                                            <ComboBoxItem Content="💊 Suplimente Mari și Vitamine"/>
                                        </ComboBox>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>
                           
                        </DataGrid.Columns>
                        
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="📊 Rapoarte &amp; Plăți" Padding="15,8" FontSize="14" FontWeight="SemiBold">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*" MinHeight="400"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <StackPanel Margin="0,0,20,0">
                                <TextBlock Text="Perioadă Raport:" FontSize="12" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,5"/>
                                <ComboBox x:Name="cbPerioada" Width="180" Height="32" SelectedIndex="0" SelectionChanged="Filtre_SelectionChanged">
                                    <ComboBoxItem Content="Toată Perioada"/>
                                    <ComboBoxItem Content="Săptămâna Curentă"/>
                                    <ComboBoxItem Content="Luna Curentă"/>
                                    <ComboBoxItem Content="Anul Curent"/>
                                    <ComboBoxItem Content="Interval Personalizat (Custom)"/>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Margin="0,0,20,0">
                                <TextBlock Text="Sursă Venit:" FontSize="12" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,5"/>
                                <ComboBox x:Name="cbSursaVenit" Width="180" Height="32" SelectedIndex="0" SelectionChanged="Filtre_SelectionChanged">
                                    <ComboBoxItem Content="Toate Sursele"/>
                                    <ComboBoxItem Content="Doar Recepție (Abonamente)"/>
                                    <ComboBoxItem Content="Doar Bar (Produse)"/>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel x:Name="panelDateCustom" Orientation="Horizontal" Visibility="Collapsed" VerticalAlignment="Center">
                                <StackPanel Margin="0,0,15,0">
                                    <TextBlock Text="De la:" FontSize="12" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,5"/>
                                    <DatePicker x:Name="dpDeLa" Width="150" Height="32" SelectedDateChanged="Filtre_SelectionChanged"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,15,0">
                                    <TextBlock Text="Până la:" FontSize="12" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,5"/>
                                    <DatePicker x:Name="dpPanaLa" Width="150" Height="32" SelectedDateChanged="Filtre_SelectionChanged"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>

                        <Button Grid.Column="1" Content="📄 Exportă Raport (PDF)" Width="180" Height="34" 
                                Background="#EF4444" Foreground="White" FontWeight="SemiBold" FontSize="13"
                                BorderThickness="0" Cursor="Hand" VerticalAlignment="Bottom" Click="BtnExportPDF_Click">
                            <Button.Resources>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="5">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#DC2626"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </Grid>

                    <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,20">
                        <Border Background="#E8F5E9" CornerRadius="8" Padding="15" Margin="0,0,5,0" BorderBrush="#2E7D32" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="Total Încasări (Finalizate)" FontSize="12" Foreground="#2E7D32" FontWeight="SemiBold"/>
                                <TextBlock x:Name="txtTotalIncasari" Text="0.00 RON" FontSize="22" FontWeight="Bold" Foreground="#1B5E20" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#E3F2FD" CornerRadius="8" Padding="15" Margin="5,0,5,0" BorderBrush="#1565C0" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="Tranzacții Procesate" FontSize="12" Foreground="#1565C0" FontWeight="SemiBold"/>
                                <TextBlock x:Name="txtNumarPlati" Text="0" FontSize="22" FontWeight="Bold" Foreground="#0D47A1" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#FFFDE7" CornerRadius="8" Padding="15" Margin="5,0,5,0" BorderBrush="#F57F17" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="În Curs / În Așteptare" FontSize="12" Foreground="#F57F17" FontWeight="SemiBold"/>
                                <TextBlock x:Name="txtNumarInProcesare" Text="0" FontSize="22" FontWeight="Bold" Foreground="#E65100" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#FFEBEE" CornerRadius="8" Padding="15" Margin="5,0,0,0" BorderBrush="#C62828" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="Comenzi/Prog. Anulate" FontSize="12" Foreground="#C62828" FontWeight="SemiBold"/>
                                <TextBlock x:Name="txtNumarAnulate" Text="0" FontSize="22" FontWeight="Bold" Foreground="#B71C1C" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.2*"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                        <DataGrid x:Name="dgVanzariRapoarte" 
                                  Grid.Column="0" 
                                  AutoGenerateColumns="False" 
                                  CanUserAddRows="False" 
                                  IsReadOnly="False" 
                                  RowHeight="38" 
                                  FontSize="14" 
                                  Margin="0,0,15,0"
                                  CellEditEnding="dgVanzariRapoarte_CellEditEnding">
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Status}" Value="Platit">
                                            <Setter Property="Background" Value="#d4edda"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Status}" Value="Anulat">
                                            <Setter Property="Background" Value="#f8d7da"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Status}" Value="InAsteptare">
                                            <Setter Property="Background" Value="#fff3cd"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>

                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Cod" Binding="{Binding Id}" Width="50" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Produs/Serviciu" Binding="{Binding NumeArticol}" Width="2*" IsReadOnly="True"/>

                                <DataGridTemplateColumn Header="Metodă" Width="1*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Metoda}" VerticalAlignment="Center" Margin="5,0"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                    <DataGridTemplateColumn.CellEditingTemplate>
                                        <DataTemplate>
                                            <ComboBox ItemsSource="{Binding DataContext.MetodePlataLista, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                  SelectedValue="{Binding Metoda, UpdateSourceTrigger=PropertyChanged}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellEditingTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="Status" Width="1*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Status}" VerticalAlignment="Center" Margin="5,0"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                    <DataGridTemplateColumn.CellEditingTemplate>
                                        <DataTemplate>
                                            <ComboBox ItemsSource="{Binding DataContext.StatusuriLista, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                  SelectedValue="{Binding Status, UpdateSourceTrigger=PropertyChanged}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellEditingTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTextColumn Header="Valoare" Binding="{Binding Suma, StringFormat=\{0:F2\}}" Width="1*"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <Border Grid.Column="1" Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="10,15,10,30">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Text="Evoluție Încasări (Ultimele 6 Luni)" FontSize="14" FontWeight="Bold" Foreground="#334155" HorizontalAlignment="Center" Margin="0,0,0,5"/>

                                <lvc:CartesianChart Grid.Row="1" 
                            Series="{Binding GraficSerii}" 
                            XAxes="{Binding GraficAxaX}" 
                            YAxes="{Binding GraficAxaY}"
                            TooltipPosition="Top"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>