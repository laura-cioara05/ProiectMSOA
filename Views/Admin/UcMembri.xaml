<UserControl x:Class="GymFitnessSystem.Views.Admin.UcMembri"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Gestiune Membri (Utilizatori)" FontSize="28" FontWeight="Bold" Foreground="#111827" Margin="10,0,0,10"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="10,0,0,15">
            <TextBlock Text="Filtrează după Rol:" VerticalAlignment="Center" Margin="0,0,15,0" FontWeight="SemiBold" Foreground="#4B5563"/>
            <RadioButton Content="Toți" IsChecked="True" Checked="FiltruRol_Checked" Tag="Toți" Style="{StaticResource {x:Type ToggleButton}}" Padding="12,5" Margin="0,0,5,0"/>
            <RadioButton Content="Administratori" Checked="FiltruRol_Checked" Tag="Administrator" Style="{StaticResource {x:Type ToggleButton}}" Padding="12,5" Margin="0,0,5,0"/>
            <RadioButton Content="Angajați" Checked="FiltruRol_Checked" Tag="Angajat" Style="{StaticResource {x:Type ToggleButton}}" Padding="12,5" Margin="0,0,5,0"/>
            <RadioButton Content="Clienți" Checked="FiltruRol_Checked" Tag="Client" Style="{StaticResource {x:Type ToggleButton}}" Padding="12,5" Margin="0,0,5,0"/>

            <Button Content="+ Adaugă Utilizator Nou" Click="AdaugaUtilizator_Click" Background="#10B981" Foreground="White" FontWeight="Bold" Padding="15,7" Margin="30,0,0,0" BorderThickness="0"/>
        </StackPanel>

        <Border Grid.Row="2" Background="White" CornerRadius="15" Padding="15" Margin="10" VerticalAlignment="Stretch">
            <DataGrid x:Name="dgUtilizatori" AutoGenerateColumns="False" CanUserAddRows="False" GridLinesVisibility="None" SelectionMode="Single" Background="Transparent" BorderThickness="0" RowHeight="45" FontSize="15" Foreground="#374151" HeadersVisibility="Column" HorizontalGridLinesBrush="#F3F4F6" CellEditEnding="dgUtilizatori_CellEditEnding" RowEditEnding="dgUtilizatori_RowEditEnding">

                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Style.Triggers>
                            <Trigger Property="Validation.HasError" Value="True">
                                <Setter Property="BorderBrush" Value="Red"/>
                                <Setter Property="BorderThickness" Value="1.5"/>
                                <Setter Property="ToolTip" 
                                        Value="{Binding RelativeSource={RelativeSource Self}, Path=(Validation.Errors)[0].ErrorContent}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.CellStyle>

                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#1E40AF"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding" Value="12,10,12,10"/>
                        <Setter Property="BorderThickness" Value="0"/>
                    </Style>
                </DataGrid.Resources>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60" IsReadOnly="True"/>

                    <DataGridTextColumn Header="Username" Width="1.2*">
                        <DataGridTextColumn.Binding>
                            <Binding Path="Username" Mode="TwoWay" ValidatesOnDataErrors="True" UpdateSourceTrigger="LostFocus"/>
                        </DataGridTextColumn.Binding>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Nume Complet" Width="1.8*">
                        <DataGridTextColumn.Binding>
                            <Binding Path="NumeComplet" Mode="TwoWay" ValidatesOnDataErrors="True" UpdateSourceTrigger="LostFocus"/>
                        </DataGridTextColumn.Binding>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Email" Width="2*">
                        <DataGridTextColumn.Binding>
                            <Binding Path="Email" Mode="TwoWay" ValidatesOnDataErrors="True" UpdateSourceTrigger="LostFocus"/>
                        </DataGridTextColumn.Binding>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Telefon" Width="1.2*">
                        <DataGridTextColumn.Binding>
                            <Binding Path="Telefon" Mode="TwoWay" ValidatesOnDataErrors="True" UpdateSourceTrigger="LostFocus"/>
                        </DataGridTextColumn.Binding>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Parolă" Width="1.1*">
                        <DataGridTextColumn.Binding>
                            <Binding Path="Parola" Mode="TwoWay" ValidatesOnDataErrors="True" UpdateSourceTrigger="LostFocus"/>
                        </DataGridTextColumn.Binding>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Data Înscrierii" Binding="{Binding DataCreare, StringFormat=\{0:dd.MM.yyyy\}}" Width="1.2*" IsReadOnly="True"/>
                    <DataGridComboBoxColumn x:Name="colRol" Header="Rol" SelectedValueBinding="{Binding Rol, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="1.3*"/>

                    <DataGridCheckBoxColumn Header="Activ" Binding="{Binding EsteActiv, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="70"/>

                    <DataGridCheckBoxColumn Header="Antrenor" Binding="{Binding EsteAntrenor, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="85"/>

                    <DataGridTemplateColumn Header="Stare" Width="1.2*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Modifică Stare" Click="SchimbaStare_Click" CommandParameter="{Binding Id}" Background="#F59E0B" Foreground="White" FontSize="12" Padding="5,3" BorderThickness="0"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>