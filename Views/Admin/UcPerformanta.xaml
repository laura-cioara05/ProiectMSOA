<UserControl x:Class="GymFitnessSystem.Views.Admin.UcPerformanta"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Monitorizare Performanță Sistem" FontSize="28" FontWeight="Bold" Foreground="#111827" Margin="10,0,0,20"/>

        <UniformGrid Grid.Row="1" Columns="2">
            <Border Background="White" CornerRadius="12" Padding="20" Margin="10">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Color="#100000" Opacity="0.1"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Utilizare Memorie RAM (Proces curent)" FontSize="16" FontWeight="SemiBold" Foreground="#4B5563" Margin="0,0,0,15"/>
                    <TextBlock x:Name="lblRam" Text="0 MB" FontSize="36" FontWeight="Bold" Foreground="#1E40AF"/>
                    <ProgressBar x:Name="prgRam" Height="15" Minimum="0" Maximum="500" Value="0" Margin="0,15,0,0" Background="#E5E7EB" Foreground="#3B82F6"/>
                </StackPanel>
            </Border>

            <Border Background="White" CornerRadius="12" Padding="20" Margin="10">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Color="#100000" Opacity="0.1"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Latență Interogare SQL (Baza de date)" FontSize="16" FontWeight="SemiBold" Foreground="#4B5563" Margin="0,0,0,15"/>
                    <TextBlock x:Name="lblSqlTime" Text="0 ms" FontSize="36" FontWeight="Bold" Foreground="#10B981"/>
                    <TextBlock x:Name="lblSqlStatus" Text="Status: Conexiune optimă" FontSize="14" Foreground="#059669" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <UniformGrid Grid.Row="2" Columns="2">
            <Border Background="White" CornerRadius="12" Padding="20" Margin="10">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Color="#100000" Opacity="0.1"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Volum Date Analizat (Sarcina Bazei de Date)" FontSize="16" FontWeight="SemiBold" Foreground="#4B5563" Margin="0,0,0,15"/>
                    <TextBlock x:Name="lblVolumeDate" Text="0 înregistrări" FontSize="36" FontWeight="Bold" Foreground="#7C3AED"/>
                    <TextBlock x:Name="lblVolumeStatus" Text="Status: Bază de date optimă" FontSize="14" Foreground="#059669" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>

            <Border Background="White" CornerRadius="12" Padding="20" Margin="10">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Color="#100000" Opacity="0.1"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Timp Randare UI Thread (Viteză Interfață)" FontSize="16" FontWeight="SemiBold" Foreground="#4B5563" Margin="0,0,0,15"/>
                    <TextBlock x:Name="lblUiTime" Text="0 ms" FontSize="36" FontWeight="Bold" Foreground="#F59E0B"/>
                    <TextBlock x:Name="lblUiStatus" Text="Stare interfață: Stabilă" FontSize="14" Foreground="#059669" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <Button Grid.Row="3" Content="⚡ Rulează Diagnostic Complet" Click="BtnDiagnostic_Click" 
            Background="#1E40AF" Foreground="White" FontWeight="Bold" Padding="12" Margin="10" BorderThickness="0" Cursor="Hand"/>

        <GroupBox Grid.Row="4" Margin="10,15,10,10" BorderBrush="#E5E7EB" BorderThickness="1">
            <GroupBox.Header>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="📋 Istoric Performanță &amp; Audit Sistem" FontSize="15" FontWeight="Bold" Foreground="#374151"/>
                </StackPanel>
            </GroupBox.Header>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" 
                   Text="Jurnal de evenimente în timp real (Trace &amp; Diagnostic Logs):" 
                   FontSize="12" 
                   FontStyle="Italic" 
                   Foreground="#6B7280" 
                   Margin="5,8,0,8"/>

                <ListBox Grid.Row="1" 
         x:Name="lstLoguri" 
         Background="#111827" 
         Foreground="#10B981" 
         FontFamily="Consolas" 
         FontSize="12" 
         Padding="10" 
         Margin="0,0,0,0">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Focusable" Value="False"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </Grid>
        </GroupBox>
    </Grid>
</UserControl>