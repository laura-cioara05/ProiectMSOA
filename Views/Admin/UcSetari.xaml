<UserControl x:Class="GymFitnessSystem.Views.Admin.UcSetari"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Configurare Setări Sistem" FontSize="28" FontWeight="Bold" Foreground="#111827" Margin="10,0,0,20"/>

        <Grid Grid.Row="1">

            <Border Background="White" CornerRadius="15" Padding="25" Margin="10" 
                    HorizontalAlignment="Center" VerticalAlignment="Top" MaxWidth="550" Width="Auto">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="2" Color="#000000" Opacity="0.08"/>
                </Border.Effect>

                <StackPanel MinWidth="450">
                    <TextBlock Text="Datele Sălii de Fitness" FontSize="18" FontWeight="Bold" Margin="0,0,0,15" Foreground="#1E40AF"/>

                    <TextBlock Text="Adresă:" Margin="0,5,0,2" FontWeight="SemiBold" Foreground="#374151"/>
                    <TextBox x:Name="txtAdresaSala" Padding="8" Margin="0,0,0,12" FontSize="14"/>

                    <TextBlock Text="Telefon Suport:" Margin="0,5,0,2" FontWeight="SemiBold" Foreground="#374151"/>
                    <TextBox x:Name="txtTelefonSuport" Padding="8" Margin="0,0,0,15" FontSize="14"/>

                    <TextBlock Text="Program Funcționare:" Margin="0,5,0,8" FontWeight="Bold" Foreground="#1E40AF" FontSize="15"/>

                    <Border Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="Luni - Vineri:" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="#4B5563"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                <ComboBox x:Name="cmbLvDeLa" Width="90" Padding="6"/>
                                <TextBlock Text="la" VerticalAlignment="Center" Margin="12,0" FontWeight="Medium"/>
                                <ComboBox x:Name="cmbLvPanaLa" Width="90" Padding="6"/>
                            </StackPanel>

                            <TextBlock Text="Sâmbătă - Duminică:" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="#4B5563"/>
                            <StackPanel Orientation="Horizontal">
                                <ComboBox x:Name="cmbSdDeLa" Width="90" Padding="6"/>
                                <TextBlock Text="la" VerticalAlignment="Center" Margin="12,0" FontWeight="Medium"/>
                                <ComboBox x:Name="cmbSdPanaLa" Width="90" Padding="6"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Button Content="Salvează Setările" Click="SalveazaSetari_Click" 
                            Background="#1E40AF" Foreground="White" FontWeight="Bold" FontSize="15" 
                            Padding="12" BorderThickness="0" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>