<Window x:Class="GymFitnessSystem.Views.Angajat.AngajatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Portal Staff - GymPro App" Height="720" Width="1280"
        WindowState="Maximized" UseLayoutRounding="True"
        WindowStartupLocation="CenterScreen">

    <Grid Background="#F3F4F6">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#1E40AF" CornerRadius="0,20,20,0">
            <StackPanel Margin="20">
                <TextBlock Text="GYM PRO" Foreground="White" FontSize="24" FontWeight="Bold" Margin="0,0,0,10"/>
                <TextBlock Text="Portal Angajat- GymPro App" Foreground="#BFDBFE" FontSize="12" FontWeight="SemiBold" Margin="2,0,0,40"/>

                <Button Content="🛒 Comenzi Bar" Click="MeniuComenzi_Click" Style="{StaticResource MenuButtonStyle}"/>
                <Button Content="📅 Check-in &amp; Activități" Click="MeniuCheckIn_Click" Style="{StaticResource MenuButtonStyle}"/>
               
                <Separator Margin="0,20" Background="#3B82F6" Opacity="0.5"/>

                <Button Content="Logout" Click="Logout_Click" Foreground="#FECACA" Background="Transparent" BorderThickness="0" FontWeight="Bold" Cursor="Hand"/>
            </StackPanel>
        </Border>

        <ContentControl Grid.Column="1" x:Name="MainContentControl" Margin="30"/>
    </Grid>
</Window>