<UserControl x:Class="GymFitnessSystem.Views.Angajat.UcGestiuneComenzi"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="White" Padding="20">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="🛒 Gestiune Comenzi Bar / Magazin" FontSize="22" FontWeight="Bold" Margin="0,0,0,15" Foreground="#1F2937"/>

        <Border Grid.Row="1" Background="#F3F4F6" CornerRadius="6" Padding="15" Margin="0,0,0,15">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Caută client (Nume/Username):" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,10,0" Foreground="#374151"/>
                <TextBox x:Name="txtCautareComenzi" Width="350" Height="32" VerticalContentAlignment="Center" Padding="5,0,0,0" TextChanged="TxtCautareComenzi_TextChanged"/>
                <Button Content="🔄 Refresh" Click="BtnRefresh_Click" Width="90" Height="32" Margin="15,0,0,0" Background="#3B82F6" Foreground="White" FontWeight="SemiBold" BorderThickness="0"/>
            </StackPanel>
        </Border>

        <DataGrid Grid.Row="2" x:Name="dgComenzi" AutoGenerateColumns="False" IsReadOnly="True" GridLinesVisibility="Horizontal" BorderThickness="1" BorderBrush="#E5E7EB" RowHeight="40" Background="White">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Client (Username)" Binding="{Binding Activitate.Utilizator.Username}" Width="150"/>
                <DataGridTextColumn Header="Nume Complet" Binding="{Binding Activitate.Utilizator.NumeComplet}" Width="180"/>
                <DataGridTextColumn Header="Produs" Binding="{Binding Activitate.Oferta.Nume}" Width="150"/>
                <DataGridTextColumn Header="Cantitate" Binding="{Binding Cantitate}" Width="80"/>
                <DataGridTextColumn Header="Status Livrare" Binding="{Binding StatusLivrare}" Width="140">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="👨‍🍳 Preparat (Gata de Ridicat)" Click="BtnPregatit_Click" Width="200" Height="40" Background="#F59E0B" Foreground="White" FontWeight="Bold" Margin="0,0,10,0" BorderThickness="0"/>
            <Button Content="✅ Marcare ca Ridicată" Click="BtnRidicata_Click" Width="180" Height="40" Background="#10B981" Foreground="White" FontWeight="Bold" Margin="0,0,10,0" BorderThickness="0"/>
            <Button Content="❌ Anulează Comanda" Click="BtnAnuleaza_Click" Width="160" Height="40" Background="#EF4444" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
        </StackPanel>
    </Grid>
</UserControl>