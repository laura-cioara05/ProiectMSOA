<UserControl x:Class="GymFitnessSystem.Views.Angajat.UcGestiuneProgramari"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="White" Padding="20">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="📅 Check-In Clienți &amp; Gestionare Servicii recepție" FontSize="22" FontWeight="Bold" Margin="0,0,0,15" Foreground="#1F2937"/>

        <Border Grid.Row="1" Background="#F3F4F6" CornerRadius="6" Padding="15" Margin="0,0,0,15">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Filtru Tip:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,5,0" Foreground="#374151"/>
                <ComboBox x:Name="cbFiltruTip" Width="180" Height="32" VerticalContentAlignment="Center" Margin="0,0,15,0" SelectionChanged="CbFiltruTip_SelectionChanged">
                    <ComboBoxItem Content="Toate Serviciile" IsSelected="True"/>
                    <ComboBoxItem Content="Doar Programări (Clase/Antrenori)"/>
                    <ComboBoxItem Content="Doar Abonamente Pure"/>
                </ComboBox>

                <TextBlock Text="Caută Client (Nume/Username):" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,10,0" Foreground="#374151"/>
                <TextBox x:Name="txtCautareProgramari" Width="250" Height="32" VerticalContentAlignment="Center" Padding="5,0,0,0" TextChanged="TxtCautareProgramari_TextChanged"/>
                <Button Content="🔄 Resetare" Click="BtnToate_Click" Width="90" Height="32" Margin="15,0,0,0" Background="#3B82F6" Foreground="White" FontWeight="SemiBold" BorderThickness="0"/>
            </StackPanel>
        </Border>

        <DataGrid Grid.Row="2" x:Name="dgProgramari" AutoGenerateColumns="False" IsReadOnly="True" GridLinesVisibility="Horizontal" BorderThickness="1" BorderBrush="#E5E7EB" RowHeight="40" Background="White">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID Activitate" Binding="{Binding IdReal}" Width="90"/>
                <DataGridTextColumn Header="Tip Element" Binding="{Binding TipElement}" Width="110"/>
                <DataGridTextColumn Header="Username" Binding="{Binding Username}" Width="120"/>
                <DataGridTextColumn Header="Nume Complet" Binding="{Binding NumeComplet}" Width="150"/>
                <DataGridTextColumn Header="Serviciu / Ședință / Pachet" Binding="{Binding NumeOferta}" Width="180"/>
                <DataGridTextColumn Header="Data &amp; Ora Alocată" Binding="{Binding DataOraText}" Width="140"/>
                <DataGridTextColumn Header="Antrenor" Binding="{Binding AntrenorText}" Width="130"/>
                <DataGridTextColumn Header="Status" Binding="{Binding StatusText}" Width="110">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button x:Name="btnValidare" Content="🛑 Bifează PREZENT / VALIDEAZĂ" Click="BtnPrezent_Click" Width="260" Height="40" Background="#10B981" Foreground="White" FontWeight="Bold" Margin="0,0,10,0" BorderThickness="0"/>
            <Button Content="❌ Anulează (Refuzat/Șters)" Click="BtnAnuleazaProgramare_Click" Width="180" Height="40" Background="#EF4444" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
        </StackPanel>
    </Grid>
</UserControl>