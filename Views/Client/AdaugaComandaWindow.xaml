<Window x:Class="GymFitnessSystem.Views.Client.AdaugaComandaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Finalizare Comandă" Height="400" Width="350" WindowStartupLocation="CenterScreen" ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="txtNumeProdus" FontSize="20" FontWeight="Bold" Foreground="#1E3A8A" Margin="0,0,0,15"/>

        <StackPanel Grid.Row="1">
            <TextBlock Text="Cantitate:" FontWeight="SemiBold"/>
            <StackPanel Orientation="Horizontal" Margin="0,5,0,15">
                <Button Content="-" Width="40" Height="40" Click="BtnMinus_Click" Background="#E5E7EB"/>
                <TextBox x:Name="txtCantitate" Text="1" Width="60" Height="40" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" IsReadOnly="True" FontSize="16"/>
                <Button Content="+" Width="40" Height="40" Click="BtnPlus_Click" Background="#E5E7EB"/>
            </StackPanel>

            <TextBlock Text="Total de plată:" FontWeight="SemiBold"/>
            <TextBlock x:Name="txtTotal" FontSize="28" FontWeight="ExtraBold" Foreground="#059669" Margin="0,0,0,15"/>

            <TextBlock Text="Metodă Plată:" FontWeight="SemiBold"/>
            <ComboBox x:Name="cmbMetodaPlata" Height="35" Margin="0,5,0,0">
                <ComboBoxItem Content="Cash"/>
                <ComboBoxItem Content="Card"/>
            </ComboBox>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Anulează" Width="100" Height="40" Margin="0,0,10,0" Click="BtnAnulare_Click" Background="#F3F4F6"/>
            <Button Content="Finalizare" Width="120" Height="40" Click="BtnFinalizare_Click" Background="#2563EB" Foreground="White" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>