<Window x:Class="GymFitnessSystem.Views.Client.ClientWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Portal Client - GymPro App" Height="720" Width="1280"
        WindowState="Maximized" UseLayoutRounding="True">

    <Window.Resources>
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="20,0,0,0"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" Margin="15,0,0,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3B82F6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="#F3F4F6">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#1E40AF" CornerRadius="0,20,20,0">
            <StackPanel Margin="20">
                <TextBlock Text="GYM PRO" Foreground="White" FontSize="24" FontWeight="Bold" Margin="0,10,0,5"/>
                <TextBlock Text="Portal Client" Foreground="#93C5FD" FontSize="12" Margin="0,0,0,40" FontWeight="Medium"/>

                <Button x:Name="btnShop" Content="🛒 Magazin &amp; Rezervări" Click="Navigatie_Click" Style="{StaticResource MenuButtonStyle}" Background="#3B82F6"/>
                <Button x:Name="btnComenzi" Content="📋 Comenzile Mele" Click="Navigatie_Click" Style="{StaticResource MenuButtonStyle}"/>
                <Button x:Name="btnProfil" Content="👤 Profilul Meu" Click="Navigatie_Click" Style="{StaticResource MenuButtonStyle}"/>
                <Button x:Name="btnInbox" Content="📩 Inbox" Click="Navigatie_Click" Style="{StaticResource MenuButtonStyle}"/>

                <Separator Margin="0,20" Background="#3B82F6"/>

                <Button x:Name="btnLogOut" Content="Logout" Click="btnLogOut_Click" 
                        Foreground="#FECACA" Background="Transparent" BorderThickness="0" 
                        FontSize="14" FontWeight="Bold" Cursor="Hand"/>
            </StackPanel>
        </Border>

        <ContentControl Grid.Column="1" x:Name="MainContentArea" Margin="30"/>
    </Grid>
</Window>