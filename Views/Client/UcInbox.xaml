<UserControl x:Class="GymFitnessSystem.Views.Client.UcInbox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             Background="White" Height="500" Width="700">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Titlu Fereastră -->
        <TextBlock Text="📩 Inbox - Notificări Sistem" FontSize="22" FontWeight="Bold" Margin="0,0,0,20" Foreground="#2C3E50"/>

        <!-- Lista de Notificări -->
        <ListBox x:Name="lbNotificari" Grid.Row="1" SelectionChanged="LbNotificari_SelectionChanged">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="#BDC3C7" BorderThickness="0,0,0,1" Padding="10" Width="640">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Titlul notificării (Bold dacă e necitită) -->
                            <TextBlock Text="{Binding Titlu}" Grid.Column="0" Grid.Row="0" FontSize="14" Margin="0,0,0,5">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding EsteCitit}" Value="False">
                                                <Setter Property="FontWeight" Value="Bold"/>
                                                <Setter Property="Foreground" Value="#2980B9"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <!-- Data Trimiterii -->
                            <TextBlock Text="{Binding DataTrimitere, StringFormat=\{0:dd.MM.yyyy HH:mm\}}" Grid.Column="1" Grid.Row="0" Foreground="Gray" FontSize="11"/>

                            <!-- Mesajul efectiv -->
                            <TextBlock Text="{Binding Mesaj}" Grid.Column="0" Grid.Row="1" Grid.ColumnSpan="2" TextWrapping="Wrap" Foreground="#555" FontSize="13"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Buton Marcare ca citit -->
        <Button Content="Marchează Toate ca Citite" Grid.Row="2" Width="180" HorizontalAlignment="Right" Margin="0,15,0,0" Padding="8" Click="BtnMarcheazaCitit_Click" Background="#27AE60" Foreground="White" FontWeight="Bold"/>
    </Grid>
</UserControl>