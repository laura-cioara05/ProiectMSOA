<UserControl x:Class="GymFitnessSystem.Views.Client.UcProfil"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F9FAFB">
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="350"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- PARTEA STÂNGA: DATE PERSONALE -->
        <Border Grid.Column="0" Background="White" CornerRadius="15" Padding="20" Margin="0,0,15,0" BorderBrush="#E5E7EB" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="Profilul Meu" FontSize="22" FontWeight="Bold" Foreground="#111827" Margin="0,0,0,20" HorizontalAlignment="Center"/>

                <TextBlock Text="Nume de utilizator" FontSize="13" FontWeight="SemiBold" Foreground="#4B5563" Margin="0,0,0,5"/>
                <TextBox x:Name="txtUsername" FontSize="14" Padding="7" Margin="0,0,0,12"/>

                <TextBlock Text="Nume Complet" FontSize="13" FontWeight="SemiBold" Foreground="#4B5563" Margin="0,0,0,5"/>
                <TextBox x:Name="txtNumeComplet" FontSize="14" Padding="7" Margin="0,0,0,12"/>

                <TextBlock Text="Email" FontSize="13" FontWeight="SemiBold" Foreground="#4B5563" Margin="0,0,0,5"/>
                <TextBox x:Name="txtEmail" FontSize="14" Padding="7" Margin="0,0,0,12"/>

                <TextBlock Text="Telefon" FontSize="13" FontWeight="SemiBold" Foreground="#4B5563" Margin="0,0,0,5"/>
                <TextBox x:Name="txtTelefon" FontSize="14" Padding="7" Margin="0,0,0,12"/>

                <TextBlock Text="Parolă Cont" FontSize="13" FontWeight="SemiBold" Foreground="#4B5563" Margin="0,0,0,5"/>
                <TextBox x:Name="txtParola" FontSize="14" Padding="7" Margin="0,0,0,25"/>

                <Button Content="Salvează Modificările" Click="SalveazaProfil_Click" Background="#2563EB" Foreground="White" FontWeight="Bold" FontSize="14" Padding="10" BorderThickness="0"/>
            </StackPanel>
        </Border>

        <!-- PARTEA DREAPTĂ: TOATE ISTORICELE FINALE -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Tabela 1: Istoric Programari -->
            <GroupBox Grid.Row="0" Header="📅 Istoric Rezervări Clase / Antrenori" FontSize="15" FontWeight="Bold" Margin="0,0,0,10" Background="White" BorderBrush="#E5E7EB">
                <DataGrid x:Name="dgIstoricProgramari" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" GridLinesVisibility="Horizontal" Background="Transparent" BorderThickness="0" RowHeight="35" FontSize="14">
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding StatusText}" Value="Prezent">
                                    <Setter Property="Background" Value="#DCFCE7"/>
                                    <Setter Property="Foreground" Value="#15803D"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding StatusText}" Value="Anulat">
                                    <Setter Property="Background" Value="#FEE2E2"/>
                                    <Setter Property="Foreground" Value="#B91C1C"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Serviciu" Binding="{Binding NumeServiciu}" Width="2*"/>
                        <DataGridTextColumn Header="Data / Ora" Binding="{Binding DataOraText}" Width="1.5*"/>
                        <DataGridTextColumn Header="Antrenor" Binding="{Binding AntrenorText}" Width="1.5*"/>
                        <DataGridTextColumn Header="Plată" Binding="{Binding MetodaPlata}" Width="1*"/>
                        <DataGridTextColumn Header="Status" Binding="{Binding StatusText}" Width="1*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>

            <!-- Tabela 2: Istoric Comenzi Bar -->
            <GroupBox Grid.Row="1" Header="🛒 Istoric Comenzi Bar" FontSize="15" FontWeight="Bold" Margin="0,0,0,10" Background="White" BorderBrush="#E5E7EB">
                <DataGrid x:Name="dgIstoricComenzi" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" GridLinesVisibility="Horizontal" Background="Transparent" BorderThickness="0" RowHeight="35" FontSize="14">
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding StatusText}" Value="Ridicata">
                                    <Setter Property="Background" Value="#DCFCE7"/>
                                    <Setter Property="Foreground" Value="#15803D"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding StatusText}" Value="Anulata">
                                    <Setter Property="Background" Value="#FEE2E2"/>
                                    <Setter Property="Foreground" Value="#B91C1C"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Produs Bar" Binding="{Binding NumeProdus}" Width="2*"/>
                        <DataGridTextColumn Header="Detalii Cantitate &amp; Preț" Binding="{Binding DetaliiCantitate}" Width="2*"/>
                        <DataGridTextColumn Header="Plată" Binding="{Binding MetodaPlata}" Width="1*"/>
                        <DataGridTextColumn Header="Status" Binding="{Binding StatusText}" Width="1*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>

            <!-- Tabela 3: Istoric Abonamente Achizitionate -->
            <GroupBox Grid.Row="2" Header="💳 Istoric Abonamente &amp; Pachete Săli" FontSize="15" FontWeight="Bold" Background="White" BorderBrush="#E5E7EB">
                <DataGrid x:Name="dgIstoricAbonamente" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" GridLinesVisibility="Horizontal" Background="Transparent" BorderThickness="0" RowHeight="35" FontSize="14">
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding StatusText}" Value="Platit">
                                    <Setter Property="Background" Value="#DCFCE7"/>
                                    <Setter Property="Foreground" Value="#15803D"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding StatusText}" Value="Anulat">
                                    <Setter Property="Background" Value="#FEE2E2"/>
                                    <Setter Property="Foreground" Value="#B91C1C"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Abonament / Serviciu" Binding="{Binding NumeAbonament}" Width="2.5*"/>
                        <DataGridTextColumn Header="Valoare Totală" Binding="{Binding ValoareText}" Width="1.5*"/>
                        <DataGridTextColumn Header="Metodă Plată" Binding="{Binding MetodaPlata}" Width="1.2*"/>
                        <DataGridTextColumn Header="Status Finanțe" Binding="{Binding StatusText}" Width="1.2*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>
        </Grid>
    </Grid>
</UserControl>