<UserControl x:Class="GymFitnessSystem.Views.Client.UcShop"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Magazin FitZone 1" FontSize="26" FontWeight="Bold" Foreground="#111827"/>
            <TextBlock Text="Achiziționează abonamente sau produse direct din contul tău." FontSize="14" Foreground="#6B7280" Margin="0,5,0,15"/>

            <Border Background="White" Padding="15" CornerRadius="12">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="1" Color="#000" Opacity="0.03"/>
                </Border.Effect>
                
                <StackPanel Orientation="Horizontal">
                    <StackPanel Margin="0,0,20,0">
                        <TextBlock Text="Tip Ofertă:" FontSize="12" FontWeight="SemiBold" Foreground="#4B5563" Margin="0,0,0,5"/>
                        <ComboBox x:Name="cmbTipOferta" Width="180" Height="35" VerticalContentAlignment="Center" SelectionChanged="CmbTipOferta_SelectionChanged">
                            <ComboBoxItem Content="Servicii / Abonamente" IsSelected="True"/>
                            <ComboBoxItem Content="Produse Bar &amp; Suplimente"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel>
                        <TextBlock Text="Filtrează după Categorie:" FontSize="12" FontWeight="SemiBold" Foreground="#4B5563" Margin="0,0,0,5"/>
                        <ComboBox x:Name="cmbCategorie" Width="220" Height="35" VerticalContentAlignment="Center" SelectionChanged="CmbCategorie_SelectionChanged"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="ItemsMagazin">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="285" Background="White" CornerRadius="15" Margin="0,0,20,20" Padding="20">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="15" ShadowDepth="2" Color="#000" Opacity="0.05"/>
                            </Border.Effect>

                            <Grid Height="250">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Background="#EFF6FF" CornerRadius="8" Padding="10,6" HorizontalAlignment="Left" Margin="0,0,0,12">
                                    <TextBlock Text="{Binding CategorieAfisare}" FontSize="11" FontWeight="Bold" Foreground="#2563EB"/>
                                </Border>

                                <StackPanel Grid.Row="1">
                                    <TextBlock Text="{Binding DenumireAfisare}" FontSize="17" FontWeight="Bold" Foreground="#1E3A8A" TextWrapping="Wrap" MaxHeight="50"/>
                                    <TextBlock Text="{Binding DescriereAfisare}" FontSize="13" Foreground="#6B7280" TextWrapping="Wrap" Margin="0,8,0,0" Height="60"/>
                                    <TextBlock Text="{Binding StocAfisare}" FontSize="11" FontWeight="SemiBold" Foreground="{Binding CuloareStoc}" Margin="0,5,0,0"/>
                                </StackPanel>

                                <Grid Grid.Row="2" Margin="0,10,0,0">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding PretAfisare, StringFormat='{}{0:N2}'}" FontSize="20" FontWeight="Bold" Foreground="#111827"/>
                                        <TextBlock Text=" RON" FontSize="13" Foreground="#6B7280" VerticalAlignment="Bottom" Margin="2,0,0,2"/>
                                    </StackPanel>

                                    <Button Content="Cumpără" 
                                            HorizontalAlignment="Right" 
                                            Padding="18,7" 
                                            Background="#2563EB" 
                                            Foreground="White" 
                                            FontWeight="Bold" 
                                            BorderThickness="0"
                                            IsEnabled="{Binding EsteDisponibil}"
                                            Tag="{Binding}"
                                            Click="BtnCumpara_Click">
                                        <Button.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="8"/>
                                            </Style>
                                        </Button.Resources>
                                    </Button>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>